## 8. Scaffolding Templates

### 8.1 New P2996 Core Test

```cpp
#include <boost/typelayout/typelayout.hpp>
#include <iostream>
#include <cstdint>

using namespace boost::typelayout;

// Define test types inline
struct MyTestStruct {
    int32_t a;
    double  b;
};

// Compile-time verification (preferred)
static_assert(
    layout_traits<MyTestStruct>::total_size == sizeof(MyTestStruct),
    "total_size must match sizeof"
);

static_assert(
    !layout_traits<MyTestStruct>::has_pointer,
    "MyTestStruct has no pointers"
);

int main() {
    constexpr auto sig = get_layout_signature<MyTestStruct>();
    std::cout << "MyTestStruct: " << sig.value << "\n";
    std::cout << "All checks passed.\n";
    return 0;
}
```

### 8.2 New C++17-Only Tools Test

```cpp
#include <boost/typelayout/tools/safety_level.hpp>
#include <iostream>
#include <cassert>
#include <string_view>

using namespace boost::typelayout;

int main() {
    // Runtime-only tests (no P2996 reflection available)
